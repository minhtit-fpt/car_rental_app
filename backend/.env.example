# === Database (PostgreSQL + PostGIS) ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ridevn?schema=public"

# === Redis (rate limiting cho /api/auth/*) ===
REDIS_URL="redis://localhost:6379"

# === JWT access token (HS256) ===
# Sinh secret ngẫu nhiên: openssl rand -base64 48
JWT_ACCESS_SECRET="CHANGE_ME_chuoi_ngau_nhien_toi_thieu_32_ky_tu"
JWT_ACCESS_TTL="15m"

# === Refresh token ===
JWT_REFRESH_TTL_DAYS="30"

# === MinIO / S3 (bucket PRIVATE cho ảnh KYC — CCCD, bằng lái, khuôn mặt) ===
# Không bao giờ để bucket này public. Chỉ phát presigned URL ngắn hạn.
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="CHANGE_ME_minio_access_key"
MINIO_SECRET_KEY="CHANGE_ME_minio_secret_key"
MINIO_KYC_BUCKET="kyc-private"
