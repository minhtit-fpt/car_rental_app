# === Database (PostgreSQL + PostGIS) ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ridevn?schema=public"

# === Redis (rate limiting cho /api/auth/*) ===
REDIS_URL="redis://localhost:6379"

# === JWT access token (HS256) ===
# Sinh secret ngẫu nhiên: openssl rand -base64 48
JWT_ACCESS_SECRET="CHANGE_ME_chuoi_ngau_nhien_toi_thieu_32_ky_tu"
JWT_ACCESS_TTL="15m"

# === Refresh token ===
JWT_REFRESH_TTL_DAYS="30"

# === MinIO / S3 (bucket PRIVATE cho ảnh KYC — CCCD, bằng lái, khuôn mặt) ===
# Không bao giờ để bucket này public. Chỉ phát presigned URL ngắn hạn.
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="CHANGE_ME_minio_access_key"
MINIO_SECRET_KEY="CHANGE_ME_minio_secret_key"
MINIO_KYC_BUCKET="kyc-private"

# Payment gateway (VNPay) — điền TMN_CODE + HASH_SECRET để bật adapter thật;
# bỏ trống → tự fallback mock (không cần credentials).
VNPAY_SANDBOX_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
# URL VNPay redirect về sau khi thanh toán; app bắt URL này trong WebView.
VNPAY_RETURN_URL=https://ridevn.app/payment/return

# === Email (SMTP qua Nodemailer) ===
# Điền đủ HOST/USER/PASS để bật gửi email khi thanh toán thành công;
# bỏ trống → tự no-op (dev không cần SMTP). Dev test gợi ý dùng Mailtrap.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Địa chỉ hiển thị "From"; bỏ trống → dùng SMTP_USER.
SMTP_FROM=

# === Cron: tự huỷ đơn quá hạn thanh toán ===
# Secret bảo vệ POST /api/cron/payment-reminders; scheduler ngoài gửi qua header
# `x-cron-secret`. Bỏ trống → endpoint trả 503 (chưa bật). Sinh: openssl rand -hex 32
CRON_SECRET=
# Số giờ kể từ khi tạo đơn mà chưa thanh toán → tự huỷ (mặc định 1).
PAYMENT_REMINDER_HOURS=1

# === LM Studio (VLM: Qwen2.5-VL để nhận diện hư hỏng xe) ===
# LM Studio phải chạy trên máy → http://localhost:1234/v1 (OpenAI-compatible)
# Tải model: https://lmstudio.ai/ → "Search" → "qwen2.5-vl-7b-instruct"
LM_STUDIO_BASE_URL="http://localhost:1234/v1"
VLM_MODEL="qwen2.5-vl-7b-instruct"
