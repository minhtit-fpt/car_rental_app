// RideVN — Prisma schema (source of truth = PostgreSQL + PostGIS)
// Plan: .claude/db-backend-plan.md  ·  ER: docs/db-structure.html
//
// B0: chỉ datasource + generator + extensions.
// Models được thêm theo từng phase: B1 Auth → B2 KYC → B3 Vehicle → B4 Booking → B5 Social → B6 Chat → B7 Audit.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, btree_gist]
}

// ============================================================
// B1 — Auth & Identity
// ============================================================

enum UserRole {
  RENTER
  OWNER
  ADMIN
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  phone        String    @unique
  email        String?   @unique
  name         String?
  passwordHash String
  // 1 user có thể giữ nhiều vai (RENTER + OWNER). ADMIN phải đứng một mình
  // (ép bằng CHECK constraint user_admin_exclusive trong migration).
  roles        UserRole[] @default([RENTER])
  kycStatus    KycStatus  @default(UNVERIFIED)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  refreshTokens   RefreshToken[]
  kyc             KYCVerification?
  vehicles        Vehicle[]
  bookings        Booking[]      // với vai RENTER
  reviewsWritten  Review[]                  @relation("ReviewAuthor")
  reviewsReceived Review[]                  @relation("ReviewTarget")
  loyaltyPoints   LoyaltyPoint[]
  tripStories     TripStory[]
  notifications   Notification[]
  conversations   ConversationParticipant[]
  messagesSent    ChatMessage[]
  auditLogs       AuditLog[]
  disputes        Dispute[]
  favorites       Favorite[]

  @@index([phone])
  @@index([roles], type: Gin)
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OTPCode {
  id         String   @id @default(uuid()) @db.Uuid
  phone      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// ============================================================
// B2 — KYC
// ============================================================

model KYCVerification {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @unique @db.Uuid
  cccdUrl    String // private bucket MinIO
  licenseUrl String // private bucket MinIO
  faceUrl    String // private bucket MinIO
  status     KycStatus @default(PENDING)
  reviewedBy String?   @db.Uuid // ADMIN duyệt
  reviewedAt DateTime?
  rejectReason String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ============================================================
// B3 — Vehicle (PostGIS)
// ============================================================

enum VehicleType {
  CAR
  MOTORBIKE
  BICYCLE
}

// Trạng thái duyệt xe của ADMIN. Xe mới mặc định PENDING; chỉ xe APPROVED
// mới hiện trên map / cho đặt. Xe hiện có được grandfather → APPROVED (migration).
enum VehicleApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Vehicle {
  id                String      @id @default(uuid()) @db.Uuid
  ownerId           String      @db.Uuid
  type              VehicleType
  title             String
  pricePerDay       Decimal     @db.Decimal(12, 2)
  isElectric        Boolean     @default(false)
  isAvailable       Boolean     @default(true)
  deliveryAvailable Boolean     @default(false)
  approvalStatus    VehicleApprovalStatus @default(PENDING)
  rejectionReason   String? // lý do ADMIN từ chối (chỉ có khi REJECTED)
  // Thông số kỹ thuật (nullable — chỉ áp dụng cho một số loại xe).
  seats             Int?
  doors             Int?
  transmission      String? // 'AUTOMATIC' | 'MANUAL'
  city              String?
  // PostGIS — Prisma không hỗ trợ native, dùng Unsupported.
  // GIST index thêm thủ công trong migration.
  location          Unsupported("geography(Point, 4326)")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  favorites Favorite[]

  @@index([ownerId])
  @@index([type])
  @@index([isAvailable])
  @@index([approvalStatus])
  @@index([location], type: Gist)
}

// ============================================================
// B3b — Favorite (xe đã lưu / tim)
// ============================================================

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  vehicleId String   @db.Uuid
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([userId, vehicleId])
  @@index([userId])
}

// ============================================================
// B4 — Booking & Tiền (Payment, Contract, Insurance)
// ============================================================

enum BookingStatus {
  PENDING_PAYMENT
  AWAITING_OWNER
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  VNPAY
  MOMO
  STRIPE
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum InsurancePlan {
  BASIC
  STANDARD
  PREMIUM
}

model Booking {
  id               String        @id @default(uuid()) @db.Uuid
  vehicleId        String        @db.Uuid
  renterId         String        @db.Uuid
  status           BookingStatus @default(PENDING_PAYMENT)
  // timestamptz để EXCLUDE constraint dùng tstzrange chống đặt trùng giờ
  startTime        DateTime      @db.Timestamptz(3)
  endTime          DateTime      @db.Timestamptz(3)
  totalPrice       Decimal       @db.Decimal(12, 2)
  deliveryRequested Boolean      @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  renter      User        @relation(fields: [renterId], references: [id], onDelete: Cascade)
  payment      Payment?
  contract     Contract?
  insurance    Insurance?
  reviews      Review[]
  tripStories  TripStory[]
  conversation ChatConversation?
  disputes     Dispute[]
  inspections  Inspection[]
  damageReport DamageReport?

  @@index([vehicleId])
  @@index([renterId])
  @@index([status])
}

enum InspectionPhase {
  CHECKIN
  CHECKOUT
}

// Ảnh kiểm tra xe khi nhận (CHECKIN) và trả (CHECKOUT). photoKeys là object key
// trong bucket private — KHÔNG public. Mỗi đơn tối đa 1 bộ ảnh mỗi phase.
model Inspection {
  id          String          @id @default(uuid()) @db.Uuid
  bookingId   String          @db.Uuid
  phase       InspectionPhase
  photoKeys   String[]
  createdById String          @db.Uuid
  createdAt   DateTime        @default(now())

  // Hư hỏng VLM phát hiện ngay tại lượt này (độc lập với lượt kia) — dùng để báo
  // cả 2 bên về tình trạng xe lúc giao/trả. null = chưa phân tích (VLM lỗi/tắt).
  findingsSummary String?
  findings        Json?
  analyzedAt      DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, phase])
  @@index([bookingId])
}

// Báo cáo hư hỏng do VLM sinh ra khi so ảnh CHECKIN ↔ CHECKOUT. items là JSON
// [{ label, severity, description }]; estimatedCost gợi ý bồi thường (VND).
model DamageReport {
  id            String   @id @default(uuid()) @db.Uuid
  bookingId     String   @unique @db.Uuid
  summary       String
  items         Json
  estimatedCost Int      @default(0)
  createdAt     DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

enum DisputePriority {
  HIGH
  MEDIUM
  LOW
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

// Tranh chấp gắn với một booking, do RENTER/OWNER tạo, ADMIN xử lý.
model Dispute {
  id          String          @id @default(uuid()) @db.Uuid
  bookingId   String          @db.Uuid
  raisedById  String          @db.Uuid
  title       String
  description String?
  priority    DisputePriority @default(MEDIUM)
  status      DisputeStatus   @default(OPEN)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  raisedBy User    @relation(fields: [raisedById], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([bookingId])
}

model Payment {
  id         String        @id @default(uuid()) @db.Uuid
  bookingId  String        @unique @db.Uuid
  method     PaymentMethod
  status     PaymentStatus @default(PENDING)
  amount     Decimal       @db.Decimal(12, 2)
  gatewayRef String?
  paidAt     DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Contract {
  id        String    @id @default(uuid()) @db.Uuid
  bookingId String    @unique @db.Uuid
  pdfUrl    String
  signedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Insurance {
  id             String        @id @default(uuid()) @db.Uuid
  bookingId      String        @unique @db.Uuid
  planType       InsurancePlan @default(BASIC)
  premium        Decimal       @db.Decimal(12, 2)
  coverageAmount Decimal       @db.Decimal(14, 2)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

// ============================================================
// B5 — Social (Review, LoyaltyPoint, TripStory, Notification)
// ============================================================

enum NotificationType {
  BOOKING
  PAYMENT
  KYC
  CHAT
  PROMOTION
  SYSTEM
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  bookingId  String   @db.Uuid
  reviewerId String   @db.Uuid
  targetId   String   @db.Uuid
  rating     Int // 1..5 — ép bằng CHECK constraint review_rating_range
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer User    @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)
  target   User    @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  // 1 người chỉ đánh giá 1 đối tượng 1 lần / booking
  @@unique([bookingId, reviewerId, targetId])
  @@index([targetId])
  @@index([bookingId])
}

model LoyaltyPoint {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  points    Int // có thể âm (tiêu điểm)
  action    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TripStory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  bookingId String?  @db.Uuid
  content   String
  images    String[] @default([])
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String
  body      String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
}

// ============================================================
// B6 — Chat (bảng nối ConversationParticipant cho nhiều-nhiều)
// ============================================================

model ChatConversation {
  id            String    @id @default(uuid()) @db.Uuid
  bookingId     String?   @unique @db.Uuid // 1 booking ↔ tối đa 1 cuộc chat
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())

  booking      Booking?                  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     ChatMessage[]
}

model ConversationParticipant {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @db.Uuid
  userId         String   @db.Uuid
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model ChatMessage {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @db.Uuid
  senderId       String    @db.Uuid
  body           String
  sentAt         DateTime  @default(now())
  readAt         DateTime?

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
  @@index([senderId])
}

// ============================================================
// B7 — AuditLog
// ============================================================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid // null = hành động hệ thống
  action    String
  target    String
  metadata  Json?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([target])
  @@index([createdAt])
}
